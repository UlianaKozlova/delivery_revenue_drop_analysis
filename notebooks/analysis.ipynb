import sys
sys.path.append('../src')

from data_loader import load_orders, load_funnel, load_marketing, preprocess
from eda import (plot_monthly_revenue, plot_metrics, plot_conversions,
                 plot_platform_revenue, plot_marketing_volume)
from stats_tests import t_test_avg_check, z_test_conversion, compare_time_periods
from utils import (aggregate_monthly_orders, aggregate_funnel,
                   aggregate_platform_metrics, aggregate_marketing)

# Загрузка
orders = load_orders()
funnel = load_funnel()
marketing = load_marketing()

orders, funnel, marketing = preprocess(orders, funnel, marketing)

# Агрегации
monthly_revenue = orders.groupby('year_month')['paid_amount'].sum().reset_index()
monthly_metrics = aggregate_monthly_orders(orders)
funnel_metrics = aggregate_funnel(funnel)
platform_metrics = aggregate_platform_metrics(orders)
marketing_metrics = aggregate_marketing(marketing)

# Визуализации
plot_monthly_revenue(monthly_revenue)
plot_metrics(monthly_metrics)
plot_conversions(funnel_metrics)
plot_platform_revenue(platform_metrics)
plot_marketing_volume(marketing_metrics)

# Статтесты
march_orders = orders[orders['year_month'].astype(str) == '2026-03']['paid_amount']
april_orders = orders[orders['year_month'].astype(str) == '2026-04']['paid_amount']
t_test_avg_check(march_orders, april_orders)

z_test_conversion(funnel)  # test vs control
compare_time_periods(marketing, orders)

